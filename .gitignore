# User-specific folders
data/
games/

# Python bytecode (prevents __pycache__ folders from appearing)
__pycache__/
*.py[cod]

# Environments (Covers all common Python virtual environment names)
.venv/
venv/
env/
ENV/
.env

# System files
.DS_Store
Thumbs.db

# ===================================================
# EXPLICIT PORTABLE PYTHON PROTECTION
# ===================================================
# Prevent Git from ignoring anything inside your custom runtime folder
!windows_python/
!windows_python/**

# Ensure critical binaries are explicitly tracked
!*.pyd
!*.dll